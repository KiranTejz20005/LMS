{
  "name": "@cio/embeds",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 5180",
    "build:question-type-picker": "vite build --mode question-type-picker",
    "build:course-widget": "vite build --mode course-widget && node -e \"fs.cpSync('src/widgets/course-widget/embed.html', 'dist/course-widget/embed.html')\"",
    "build": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\" && pnpm build:question-type-picker && pnpm build:course-widget",
    "preview": "vite preview --port 4180"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.388.0",
    "@cio/tsconfig": "workspace:*",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/vite": "^4.1.16",
    "svelte": "^5.39.11",
    "dotenv": "^16.3.1",
    "tsx": "^4.7.1",
    "typescript": "^5.5.0",
    "vite": "^7.1.4",
    "tailwindcss": "^4.1.16",
    "vite-plugin-css-injected-by-js": "^3.5.2"
  },
  "dependencies": {
    "@cio/ui": "workspace:*",
    "@cio/utils": "workspace:*",
    "@cio/question-types": "workspace:*",
    "@lucide/svelte": "^0.562.0"
  }
}
