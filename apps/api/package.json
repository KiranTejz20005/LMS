{
  "name": "@cio/api",
  "version": "0.0.1",
  "description": "GurukulX Backend for long processes",
  "main": "dist/index.js",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && tsc-alias",
    "build:clean": "node -e \"fs.rmSync('dist',{recursive:true,force:true});fs.rmSync('tsconfig.tsbuildinfo',{recursive:true,force:true})\" && pnpm run build",
    "dev": "pnpm --filter @cio/api --parallel \"/^dev:.*/\"",
    "dev:server": "tsx watch src/index.ts",
    "dev:tsc": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "start": "node dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GurukulX/GurukulX.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/gurukulx/gurukulx/issues"
  },
  "homepage": "https://github.com/gurukulx/gurukulx#readme",
  "exports": {
    "./rpc-types": {
      "types": "./dist/rpc-types.d.ts",
      "default": "./dist/rpc-types.js"
    }
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.388.0",
    "@aws-sdk/s3-request-presigner": "^3.675.0",
    "@bull-board/api": "^7.0.0",
    "@bull-board/hono": "^7.0.0",
    "@cio/ai-assistant": "workspace:*",
    "@cio/analytics": "workspace:*",
    "@cio/certificates": "workspace:*",
    "@cio/db": "workspace:*",
    "@cio/email": "workspace:*",
    "@cio/jobs": "workspace:*",
    "@cio/question-types": "workspace:*",
    "@cio/utils": "workspace:*",
    "@hono/node-server": "^1.19.7",
    "@hono/standard-validator": "^0.1.5",
    "@hono/zod-validator": "^0.7.6",
    "@scalar/hono-api-reference": "^0.9.18",
    "@sentry/node": "^10.53.1",
    "ai": "^6.0.158",
    "axios": "^1.4.0",
    "css-tree": "^3.2.1",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.44.7",
    "hono": "^4.11.3",
    "hono-openapi": "^1.0.8",
    "hono-rate-limiter": "^0.4.2",
    "isomorphic-dompurify": "^3.7.1",
    "jszip": "^3.10.1",
    "katex": "^0.16.10",
    "mammoth": "^1.9.0",
    "marked": "^7.0.3",
    "nanoid": "^5.1.5",
    "pdf-parse": "^1.1.1",
    "redis": "^4.7.0",
    "zod": "^4.1.8",
    "zod-openapi": "^5.4.1"
  },
  "devDependencies": {
    "@types/katex": "^0.16.7",
    "@types/node": "^20.19.0",
    "@types/pdf-parse": "^1.1.5",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.7.1",
    "typescript": "^5.5.2"
  }
}
